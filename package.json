{
  "name": "ai-job-agent",
  "version": "1.0.0",
  "description": "Autonomous AI job application agent built on Anthropic API",
  "main": "dist/index.js",
  "bin": {
    "job-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "apply": "ts-node src/index.ts apply",
    "server": "ts-node server/index.ts",
    "web:install": "cd web && npm install",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "dev:full": "concurrently \"npm run server\" \"npm run web:dev\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "archiver": "^7.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.19.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
